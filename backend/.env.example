# Server port - app yahan chalega
PORT=5000

# MongoDB connection string - apna local ya Atlas URL daalo
MONGO_URI=mongodb://127.0.0.1:27017/hiresense-ai

# JWT secret - production me strong random string use karo
JWT_SECRET=apna_super_secret_key_yahan_dalo
JWT_EXPIRE=7d

# Google Gemini API - resume AI analysis ke liye
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Evaluation: auto (LLM + fallback) | gemini (LLM only) | local (rule-based)
EVALUATION_MODE=auto
